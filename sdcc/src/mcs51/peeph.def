	mov	a,%1
	addc	a,#0x00
} by {
	;	Peephole 240	use clr instead of addc a,#0
	clr	a
	addc	a,%1
}

// peepholes 241.a0 to 241.d and 241.e0 to 241.h need to be in order
replace {
	cjne	r%2,#%3,%0
	cjne	r%4,#%5,%0
	cjne	r%6,#%7,%0
	cjne	r%8,#%9,%0
	cjne	r%10,#%11,%0
	cjne	r%12,#%13,%0
	cjne	r%14,#%15,%0
