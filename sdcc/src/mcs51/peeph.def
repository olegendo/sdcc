// applies to: a = (a << 1) | (a >> 15);
replace {
	mov	a,%1
	rlc	a
	mov	%1,a
	mov	a,%2
	rlc	a
	mov	%2,a
	mov	a,%1
	mov	acc.0,c
	mov	%1,a
} by {
	mov	a,%1
	rlc	a
	;	Peephole 261.a	optimized left rol
	xch	a,%2
	rlc	a
	xch	a,%2
	mov	acc.0,c
	mov	%1,a
}

// applies to: a = (a << 15) | (a >> 1);
replace {
	mov	a,%1
	rrc	a
	mov	%1,a
	mov	a,%2
	rrc	a
	mov	%2,a
	mov	a,%1
	mov	acc.7,c
	mov	%1,a
} by {
	mov	a,%1
	rrc	a
	;	Peephole 261.b	optimized right rol
	xch	a,%2
	rrc	a
	xch	a,%2
	mov	acc.7,c
	mov	%1,a
}

replace {
	cpl	c
	cpl	c
} by {
	;	Peephole 262	removed redundant cpl c
}

replace {
	mov	%1,#%2
	inc	%1
	inc	%1
	inc	%1
} by {
	;	Peephole 263.a	optimized loading const
	mov	%1,#(%2 + 3)
} if notVolatile(%1)

replace {
	mov	%1,#%2
	inc	%1
	inc	%1
} by {
	;	Peephole 263.b	optimized loading const
	mov	%1,#(%2 + 2)
} if notVolatile(%1)

replace {
	mov	%1,#%2
	inc	%1
} by {
	;	Peephole 263.c	optimized loading const
	mov	%1,#(%2 + 1)
} if notVolatile(%1)


replace {
	clr	a
	cjne	%1,%2,%3
	inc	a
%3:
	jz	%4
} by {
	;	Peephole 264	jump optimization (acc not set)
	cjne	%1,%2,%4
%3:
} if labelRefCount(%3 1), labelRefCountChange(%3 -1)


replace {
	mov	%1,c
	cpl	%1
} by {
	;	Peephole 265	optimized mov/cpl sequence (carry differs)
	cpl	c
	mov	%1,c
} if notVolatile(%1)

replace {
	mov	%1,c
	jb	%1,%2
} by {
	;	Peephole 266.a	optimized mov/jump sequence
	mov	%1,c
	jc	%2
} if notVolatile(%1)

replace {
	mov	%1,c
	jnb	%1,%2
} by {
	;	Peephole 266.b	optimized mov/jump sequence
	mov	%1,c
	jnc	%2
} if notVolatile(%1)

replace {
	jnc	%1
	setb	%2
	sjmp	%3
%1:
	clr	%2
%3:
} by {
	;	Peephole 267.a	optimized mov bit sequence
	mov	%2,c
%1:
%3:
} if labelRefCount(%1 1), labelRefCountChange(%1 -1), labelRefCountChange(%3 -1)

replace {
	jc	%1
	clr	%2
	sjmp	%3
%1:
	setb	%2
%3:
} by {
	;	Peephole 267.b	optimized mov bit sequence
	mov	%2,c
%1:
%3:
} if labelRefCount(%1 1), labelRefCountChange(%1 -1), labelRefCountChange(%3 -1)

replace {
	mov	%1,c
	mov	%1,c
} by {
	;	Peephole 268	removed redundant mov
	mov	%1,c
} if notVolatile(%1)

replace {
	mov	%1,c
	mov	c,%1
} by {
	;	Peephole 269	removed redundant mov
	mov	%1,c
} if notVolatile(%1)

//accessing struct/array on stack
//replace {
//	add	a,#%1
//	add	a,#%2
//} by {
//	;	Peephole 270	removed redundant add (carry might differ, bug 2736282)
//	add	a,#%1+%2
//}

replace {
	jz	%1
	mov	%2,%4
	sjmp	%3
%1:
	mov	%2,#0x00
%3:
} by {
	jz	%1
	;	Peephole 271	optimized ternary operation (acc different)
	mov	a,%4
%1:
	mov	%2,a
%3:
} if operandsNotRelated('a' 'dptr' %2), labelRefCount(%1 1), labelRefCountChange(%3 -1)


// left-shifting 8 bit to 16 bit result
// http://sourceforge.net/projects/sdcc/forums/forum/1864/topic/3536144
replace {
	clr	a
	swap	a
} by {
	clr	a
	;	Peephole 272.a	removed swap operation on zero
}

replace {
	clr	a
	anl	a,%1
} by {
	clr	a
	;	Peephole 272.b	removed anl operation on zero
} if notVolatile(%1)

replace {
	clr	a
	mov	c,acc.0
} by {
	clr	a
	;	Peephole 272.c	clearing carry directly
	clr	c
}

replace {
	mov	%1,dpl
	mov	%2,dph
	mov	%3,b
	push	a%3
	push	a%2
	push	a%1
} by {
	; Peephole 273 5627 optimized push
	push	b
	push	dph
	push	dpl
	mov	%1,dpl
	mov	%2,dph
	mov	%3,b
}

replace {
	mov	%1,dpl
	mov	%2,dph
	mov	%3,b
	push	a%1
	push	a%2
	push	a%3
} by {
	; Peephole 273 5644 optimized push
	push	dpl
	push	dph
	push	b
	mov	%1,dpl
	mov	%2,dph
	mov	%3,b
}


replace {
	mov	%1,dpl
	mov	%2,dph
	push	a%2
	push	a%1
} by {
	; Peephole 273.1 optimized push
	push	dph
	push	dpl
	mov	%1,dpl
	mov	%2,dph
}

replace {
	mov	%1,dpl
	mov	%2,dph
	push	a%1
	push	a%2
} by {
	; Peephole 273.1 optimized push
	push	dpl
	push	dph
	mov	%1,dpl
	mov	%2,dph
}

replace {
	pop	a%1
	pop	a%2
	pop	a%3
	mov	dpl,%1
	mov	dph,%2
	mov	b,%3
} by {
	; Peephole 273 5688 optimized pop
	pop	dpl
	pop	dph
	pop	b
	mov	%1,dpl
	mov	%2,dph
	mov	%3,b
}

replace	{
	pop	a%1
	pop	a%2
	mov	dpl,%1
	mov	dph,%2
} by {
	; Peephole 273.2 optimized pop
	pop	dpl
	pop	dph
	mov	%1,dpl
	mov	%2,dph
}

replace {
	pop	a%1
	pop	a%2
	mov	%3,%1
} by {
	; Peephole 273.3 optimized pop
	pop	%3
	pop	a%2
	mov	%1,%3
} if same(%3 'dpl' 'dph' 'b')


replace {
	pop	a%1
	mov	%2,%1
} by {
	; Peephole 273.4 optimized pop
	pop	%2
	mov	%1,%2
} if same(%2 'dpl' 'dph' 'b')

replace {
	mov	%1,%2
	push	a%1
} by {
	; Peephole 273 optimized push
	push	%2
	mov	%1,%2
} if same(%2 'dpl' 'dph' 'b')


replace restart {
	pop	ar%1
} by {
	;	Peephole 300	pop ar%1 removed
} if deadMove(%1)

// try to eliminate unneeded push-pop around a function call, if the
// popped register is not used after the call.
// this might be risky as we don't really know for sure whether those
// push-pop pairs are real or whether it's an argument push + stack adjust
// or something else.
// this will also miss lots of opportunities, because it doesn't see across
// other insns that might be interleaved.  and it also doesn't check whether
// the pushed value is used by the function call (as an input parameter on
// the stack).
replace restart {
	push	%1
	%2	%3
	pop	%4
} by {
	; peephole 6112
	%2	%3
} if same(%2 'lcall' 'acall'), notSame(%1 'acc'), notUsed(%4)

// N.B. this can brake callee-save if the call reg uses bits
//      aren't set properly.
replace restart {
	pop	a%1
} by {
	;	Peephole 300.1	pop a%1 -> dec sp
	dec	sp
} if same(%1 'r0' 'r1' 'r2' 'r3' 'r4' 'r5' 'r6' 'r7'), notUsed(%1)


replace restart {
	push	ar%1
} by {
	;	Peephole 301	push ar%1 removed
} if deadMove(%1)

replace restart {
	mov	ar%1,%2
} by {
	;	Peephole 303	mov ar%1,%2 removed
} if notVolatile(%2), deadMove(%1)

replace restart {
	mov	%1,%2
} by {
	;	Peephole 304	mov %1,%2 removed
} if notVolatile(%2), same(%1 'a' 'dpl' 'dph' 'b' 'r0' 'r1' 'r2' 'r3' 'r4' 'r5' 'r6' 'r7'), notUsed(%1)

// pattern 304 catches most dead loads of immediates.
// however direct addresses of variables might not always pass the notVolatile
// it seems and will get stuck around.
// FIXME: dptr not supported as register, but it should be.
replace restart {
	mov	%1,#%2
} by {
	; peephole 304.1
} if same(%1 'a' 'dpl' 'dph' 'b' 'r0' 'r1' 'r2' 'r3' 'r4' 'r5' 'r6' 'r7'), notUsed(%1)

replace restart {
	clr	a
} by {
	; Peephole 304.1  clr a removed
} if notUsed('a')

replace restart {
	cpl	%1
} by {
	; Peephole 304.2  cpl %1 removed
} if same(%1 'a' 'c' 'b0' 'b1' 'b2' 'b3' 'b4' 'b5' 'b6' 'b7'), notUsed(%1)

replace restart {
	mov	a,%1
} by {
	; Peephole 304.2  mov a,%1 removed
} if isSpecialRegister(%1 'acc')

replace restart {
	mov	%1,%2
} by {
	; Peephole 304.2_1  mov a,%1 removed
	mov	a,%2
} if isSpecialRegister(%1 'acc')

replace restart {
	mov	%1,%2
} by {
	; Peephole 304.2_2  mov a,%1 removed
	mov	%1,a
} if isSpecialRegister(%2 'acc')

replace {
	%1	a,a
} by {
	; Peephole 5873 mov a,a  removed
} if same(%1 'mov' 'xch')

replace {
	mov	%2,a%1
} by {
	; Peephole 304.2_3  mov a%1,%2 -> mov %1,%2
	mov	%2,%1
} if notSame(%2 'r0' 'r1' 'r2' 'r3' 'r4' 'r5' 'r6' 'r7' '@r0' '@r1'), same(%1 'r0' 'r1' 'r2' 'r3' 'r4' 'r5' 'r6' 'r7')

replace {
	mov	a%1,%2
} by {
	; Peephole 304.2_3  mov a%1,%2 -> mov %1,%2
	mov	%1,%2
} if notSame(%2 'r0' 'r1' 'r2' 'r3' 'r4' 'r5' 'r6' 'r7' '@r0' '@r1'), same(%1 'r0' 'r1' 'r2' 'r3' 'r4' 'r5' 'r6' 'r7')

replace restart {
	%4	a,%1
} by {
	; Peephole 304.3	removed dead computation  %4  a,%1
} if same(%4 'add' 'addc' 'subb'), notUsed('a'), notUsed('C'), notVolatile(%1)

replace restart {
	%4	a
} by {
	; Peephole 304.4	removed dead computation   %4  a
} if same(%4 'rlc' 'rrc'), notUsed('a'), notUsed('C')

replace restart {
	%4	a,%1
} by {
	; Peephole 304.5	removed dead computation   %4  a,%1
} if same(%4 'anl' 'orl' 'xrl'), notUsed('a'), notVolatile(%1)

replace restart {
	%4	ar%1,%2
} by {
	; Peephole 304.5_1	removed dead computation  %4  a%1,%2
} if same(%4 'anl' 'orl' 'xrl'), notUsed(%1), notVolatile(%2)

replace restart {
	clr	a
	%4	a,%1
} by {
	; Peephole 304.5_2	removed dead computation  %4  a,%1
	mov	a,%1
} if same(%4 'orl' 'xrl')

replace restart {
	%4	a
} by {
	; Peephole 304.6	removed dead computation   %4  a
} if same(%4 'rr' 'rl' 'inc' 'dec' 'swap'), notUsed('a')

replace restart {
	%4	%1
} by {
	; Peephole 304.6   removed dead computation  %4 %1
} if same(%4 'inc' 'dec'), same(%1 'r0' 'r1' 'r2' 'r3' 'r4' 'r5' 'r6' 'r7' 'dpl' 'dph' 'b'), notUsed(%1)

replace restart {
	mov	%1,%2
	mov	%3,%4
	mov	%1,%2
} by {
	; Peephole 861  removed redunandant load
	mov	%1,%2
	mov	%3,%4
} if notVolatile(%1 %2), operandsNotRelated(%3 %1 %2)

replace restart {
	mov	%1,%2
	%5	%3,%4
	%6	%7
	mov	%1,%2
} by {
	; Peephole 861  removed redunandant load
	mov	%1,%2
	%5	%3,%4
	%6	%7
} if notSame(%6 'push' 'pop'), notVolatile(%1 %2), operandsNotRelated(%3 %1 %2 'sp'), operandsNotRelated(%7 %1 %2 'sp')

replace restart {
	anl	a,#0x01
	%4	%5,%6
	rrc	a
} by {
	; peephole 864 removed carry bit round trip from unpack-pack bits
	%4	%5,%6
	mov	c,acc.0
} if operandsNotRelated('a' %5 %6), notUsed('a')


replace restart {
	anl	a,#0x01
	add	a,#0xff
} by {
	; peephole 6261
	mov	c,acc.0
} if notUsed('a')

replace restart {
	clr	a
	rlc	a
	add	a,#0xff
} by {
	; peephole 6270
} if notUsed('a')

replace restart {
	rr	a
	rr	a
	mov	c,acc.0
} by {
	mov	c,acc.2
} if notUsed('a')

replace restart {
	rr	a
	mov	c,acc.0
} by {
	mov	c,acc.1
} if notUsed('a')

replace restart {
	swap	a
	mov	c,acc.0
} by {
	mov	c,acc.4
} if notUsed('a')

replace restart {
	rl	a
	mov	c,acc.0
} by {
	rlc	a
} if notUsed('a')

replace restart {
	rl	a
	rlc	a
} by {
	mov	c,acc.6
} if notUsed('a')

replace restart {
	mov	c,acc.0
} by {
	; Peephole 7343
	rrc	a
} if notUsed('a')

replace {
	%4	c
} by {
	; Peephole 304.3 clr c removed
} if notUsed('C'), same(%4 'clr' 'setb')

// dead store of virtual bit registers
replace restart {
	mov	%1,c
} by {
	;   Peephole 305	mov	%1,c removed
} if same(%1 'b0' 'b1' 'b2' 'b3' 'b4' 'b5' 'b6' 'b7'), deadMove(%1)

replace restart {
	%4	%1
} by {
	;	Peephole 305.2	removed dead virtual bit register use
} if same(%4 'anl' 'orl'), same(%1 'b0' 'b1' 'b2' 'b3' 'b4' 'b5' 'b6' 'b7'), notUsed(%1)

replace restart {
	mov	b%1,c
	mov	c,b%2
	%4	c,b%1
} by {
	mov	b%1,c
	%4	c,b%2
} if same(%4 'anl' 'orl')

replace restart {
	mov	b%1,c
	mov	c,%2
	%4	c,b%1
} by {
	mov	b%1,c
	%4	c,%2
} if same(%4 'anl' 'orl')

replace restart {
	movx	a,%1
} by {
	;	Peephole 306.a  removed unused movx load
} if same(%1 '@dptr'), notUsed('a'), notVolatile(%1)

replace restart {
	inc	dptr
} by {
	;	Peephole 306.b	removed unused inc dptr
