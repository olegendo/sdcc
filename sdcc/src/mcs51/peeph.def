%2:
	ljmp	%3
} by {
	sjmp	%1
	;	Peephole 259.e	removed redundant label %2 and ljmp %3
} if labelRefCount(%2 0)

replace {
	ljmp	%1
%2:
	ljmp	%3
} by {
	ljmp	%1
	;	Peephole 259.f	removed redundant label %2 and ljmp %3
} if labelRefCount(%2 0)


