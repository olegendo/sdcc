	%4	c,acc.%6
} if same(%4 'anl' 'orl'), immdInRange(0 7 '+' %5 1 %6), notUsed('a')

replace restart {
	clr	a
	mov	r%1,#0x00
	mov	r%2,#0x00
	mov	r%3,#0x00
	mov	r%4,#0x00
} by {
	clr	a
	mov	r%1,a
	mov	r%2,a
	mov	r%3,a
	mov	r%4,a
}

