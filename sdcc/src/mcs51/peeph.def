replace restart {
	mov	%1,a
	%2	a,%1
} by {
	; peephole 304.2/8324   %2 with itself removed
	mov	%1,a
} if same(%2 'anl' 'orl')

replace restart {
	mov	c,%1
	%2	c,%1
} by {
	; peephole 8152/8332
	mov	c,%1
} if same(%2 'anl' 'orl'), notVolatile(%1)

// happens when writing the return value of a function to a __xdata variable
replace restart {
	mov	%1,dpl
	mov	dptr,%2
