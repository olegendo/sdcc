	anl	a,#0x01
	add	a,#0xff
	clr	a
	rlc	a
	add	a,#0xff
} by {
	; Peephole 132.a0 removed carry bit round trip
	addc	a,%1
}

replace {
	clr	a
	rlc	a
	add	a,#0xff
} by {
	; Peephole 132.a1 removed carry bit round trip
} if notUsed('a')

