// 147: Fix compiler output to comply with 8051 instruction set.
replace {
	%3	r%1,%2
} by {
	;	Peephole 147.a	changed target address mode r%1 to ar%1
	%3	ar%1,%2
} if same(%3 'anl' 'orl' 'xrl')

