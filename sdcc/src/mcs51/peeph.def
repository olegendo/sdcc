	%5	%1,%2
	mov	r%3,#0x00
} by {
	clr	a
	%5	%1,%2
	mov	r%3,a
} if operandsNotRelated('a' %1 %2 %3)



// hoist loads of 'a' in the hope that it eliminate a reg-reg move.
// FIXME: should also do that with arbitrary registers, but the peephole processing
//        will loop.  need to do as a special pass
replace start {
	%4	%1,%2
	mov	a,%3
} by {
	; peephole 8131
	mov	a,%3
	%4	%1,%2
} if operandsNotRelated('a' %1 %2 %3 'sp' '@r0' '@r1'), notVolatile(%3), operandsNotRelated(%4 'call' 'jmp' 'cjne' 'djnz' 'jc' 'jnc' 'jb' 'jnb' 'jbc' 'jz' 'jnz' 'ret')

// hoist loads of 'a' in the hope that it eliminate a reg-reg move.
replace start {
	%4	%1
	mov	a,%3
} by {
	; peephole 8141
	mov	a,%3
	%4	%1
} if operandsNotRelated('a' %1 %3 'sp' '@r0' '@r1'), notVolatile(%3), same(%4 'inc' 'dec' 'clr')

// sink constant loads in the hope that they will combine with the operation
// that uses them.  it oscillates with pattern 8131 and creates an infinite loop.
//replace restart {
//	mov	r%1,#%2
//	%3	%4,%5
//} by {
//	; peephole 8152
//	%3	%4,%5
//	mov	r%1,#%2
//} if operandsNotRelated(%1 %4 %5)

// hoist computations of 'a' in the hope that it will combine better with
// previous loads of 'a' or computation results
replace {
	%1	%2,%3
	%4	a
} by {
	; peephole 8219
	%4	a
	%1	%2,%3
} if operandsNotRelated('a' %2 %3 'sp' '@r0' '@r1' 'c'), operandsNotRelated(%1 'mov' 'call' 'jmp' 'cjne' 'djnz' 'jc' 'jnc' 'jb' 'jnb' 'jbc' 'jz' 'jnz' 'ret')

replace {
	mov	%2,%3
	%4	a,%5
} by {
	; peephole 8228
	%4	a,%5
	mov	%2,%3
} if notSame(%4 'mov' 'movx'), operandsNotRelated('a' %2 %3 'sp' '@r0' '@r1' 'c' %5), notVolatile(%5)

replace {
	mov	%2,%3
	%6	%1,#%5
} by {
	; peephole 8237
	%6	%1,#%5
	mov	%2,%3
} if notSame(%6 'mov' 'movx'), same(%1 'ar0' 'ar1' 'ar2' 'ar3' 'ar4' 'ar5' 'ar6' 'ar7'), operandsNotRelated(%1 %2 %3 'sp' '@r0' '@r1' 'c')


